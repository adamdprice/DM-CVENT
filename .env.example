# Cvent API
CV_CLIENT_ID=your_cvent_client_id
CV_CLIENT_SECRET=your_cvent_client_secret

# HubSpot (Dealmakers account) – required for attendee sync
CustomCode=your_hubspot_private_app_token

# API base (optional): use EU endpoint if your account is in Europe
# CV_API_BASE=https://api-platform.cvent.com
# CV_API_BASE=https://api-platform-eur.cvent.com

# App auth (email one-time code)
# If SESSION_SECRET + SMTP_HOST + EMAIL_FROM are set, login is required.
SESSION_SECRET=replace_with_long_random_secret
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=your_smtp_or_sendgrid_api_key
EMAIL_FROM=no-reply@yourdomain.com

# Optional: comma-separated allow list for sign-in
# ALLOWED_EMAILS=you@domain.com,other@domain.com
